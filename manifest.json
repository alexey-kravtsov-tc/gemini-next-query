{
  "manifest_version": 3,
  "name": "Gemini Next Queries",
  "version": "1.1",
  "description": "Predicts next queries in Gemini chat",
  "permissions": ["storage"],
  "host_permissions": ["*://gemini.google.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://gemini.google.com/*"],
      "js": ["content.js"]
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  }
}
